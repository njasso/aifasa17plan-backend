{
  "name": "aifasa17-backend",
  "version": "2.0.0",
  "description": "AIFASA 17 - Gestion associative - Backend API pour l'Association Ivoirienne des Filles et Fils d'Abidjan Sanwi",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "seed": "node scripts/seed.js",
    "seed:dev": "node scripts/seed.js --env=development",
    "seed:prod": "node scripts/seed.js --env=production",
    "db:backup": "node scripts/backup.js",
    "db:restore": "node scripts/restore.js",
    "db:clean": "node scripts/clean-db.js",
    "generate:jwt": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "env:check": "node scripts/check-env.js",
    "env:example": "cp .env.example .env",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "coverage": "node --test --experimental-test-coverage",
    "precommit": "npm run lint && npm run security:audit",
    "prepare": "husky install",
    "docs": "jsdoc -c jsdoc.json",
    "start:prod": "NODE_ENV=production node server.js",
    "start:staging": "NODE_ENV=staging node server.js",
    "health": "curl http://localhost:5000/health",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs aifasa17",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "eslint": "^9.4.0",
    "globals": "^15.3.0",
    "husky": "^9.0.11",
    "jsdoc": "^4.0.3",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.10",
    "prettier": "^3.3.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "lint-staged": {
    "**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "aifasa17",
    "association",
    "gestion",
    "api",
    "mongoose",
    "express",
    "abidjan",
    "sanwi",
    "cote-d-ivoire"
  ],
  "author": "AIFASA 17",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aifasa17/backend.git"
  },
  "bugs": {
    "url": "https://github.com/aifasa17/backend/issues"
  },
  "homepage": "https://aifasa17.org"
}
